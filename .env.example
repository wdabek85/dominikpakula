# ── Baza danych ─────────────────────────────────────────────
DB_NAME=
DB_USER=
DB_PASSWORD=
# Opcjonalne (domyślnie localhost / wp_):
# DB_HOST=localhost
# DB_PREFIX=wp_
# DB_SSL=false
# Alternatywnie zamiast DB_* powyżej:
# DATABASE_URL=mysql://user:password@host:3306/dbname

# ── Środowisko ──────────────────────────────────────────────
# production | staging | development | local
WP_ENV=production
WP_HOME=https://example.com
WP_SITEURL=${WP_HOME}/wp

# Opcjonalne:
# WP_ENVIRONMENT_TYPE=production
# WP_DEVELOPMENT_MODE=
# WP_POST_REVISIONS=true
# DISABLE_WP_CRON=true

# ── Salty (wygeneruj NOWE na każde środowisko) ──────────────
# https://roots.io/salts.html
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=

# ── Brevo (newsletter) ──────────────────────────────────────
# Bez tych zmiennych integracja newslettera jest cicho pomijana.
BREVO_API_KEY=
BREVO_LIST_ID=
# Opcjonalne (double opt-in — wymaga szablonu DOI z panelu Brevo):
# BREVO_DOI_TEMPLATE_ID=
# BREVO_DOI_REDIRECT_URL=
